# This program prints back out the passed CLI arguments.

# if [0] is non-empty, print it and assign to zero to break the loop
(0 [0 : 0])

# assign to index of the next char
[0 1]

# keep printing chars until NULL is reached
([0]
  [[0] :]
  [0 +]
)

# also output a newline (10 is ascii newline code)
[0 10 :]
